let i = 1
for(i; i % 1 === 0; i++){
    if(i % 3 !== 0 && i % 5 !== 0){
        console.log(i)
    }
    else if(i % 3 === 0 && i % 5 !== 0){
        console.log("Fizz")
    }
    else if(i % 3 !== 0 && i % 5 === 0){
        console.log("Buzz")
    }
    else if(i % 3 === 0 && i % 5 === 0){
        console.log("FizzBuzz")
    }
}
